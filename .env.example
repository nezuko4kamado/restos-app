# Klippa OCR API Configuration
KLIPPA_API_KEY=your_klippa_api_key_here

# OCR Provider Configuration (Legacy - kept for compatibility)
# Options: 'openai' (recommended, no geographic restrictions) or 'gemini' (may have restrictions)
VITE_OCR_PROVIDER=klippa

# OpenAI API Key (for OCR with GPT-4 Vision) - Legacy fallback
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model Configuration - Legacy fallback
# Options: gpt-5.1 (default, latest), gpt-4o, gpt-4-turbo, gpt-4-vision-preview
# GPT-5.1 is now available and set as default for best OCR performance
# VITE_OPENAI_MODEL=gpt-5.1

# OpenAI API Type Configuration - Legacy fallback
# Options: chat (default, Chat Completions API), responses (Responses API)
# 'chat' is recommended for maximum compatibility with all models
# 'responses' is the new endpoint recommended by OpenAI for GPT-5.1
# Note: If Responses API fails, system automatically falls back to Chat Completions API
# VITE_OPENAI_API_TYPE=chat

# Google Gemini API Key (fallback OCR provider) - Legacy fallback
# Get your key at: https://makersuite.google.com/app/apikey
VITE_GOOGLE_API_KEY=your_google_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key