    return await getOrdersFromSupabase();
  }
  return getOrdersFromLocalStorage();
};

export const saveOrders = async (orders: Order[]): Promise<void> => {
  if (getStorageMode() === 'supabase') {
    const userId = await getUserId();
    if (!userId) throw new Error('User not authenticated');

    console.log('💾 Saving orders to Supabase...', orders.length);

    // Use upsert for each order
    for (const order of orders) {
      try {
        const dbOrder = mapOrderToDb(order, userId);
        const { error } = await supabase
          .from('orders')
          .upsert(dbOrder);
        
        if (error) throw error;
      } catch (error) {
        console.error('❌ Error saving order:', order.id, error);
        throw error;
      }
    }

    console.log('✅ Orders saved to Supabase successfully!');
  } else {
    saveOrdersToLocalStorage(orders);
  }
};

