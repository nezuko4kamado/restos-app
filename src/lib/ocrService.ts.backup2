          amount_subtotal: { value: 33.88, confidence: 0.94 },
          amount_tax: { value: 7.12, confidence: 0.93 },
          currency: { value: "EUR", confidence: 0.98 }
        },
        vendor_details: {
          vendor_name: { value: "Demo Supplier", confidence: 0.96 },
          vendor_address: { value: "Calle Demo 123, Madrid", confidence: 0.92 },
          vendor_vat_number: { value: "ES12345678Z", confidence: 0.94 },
          vendor_phone: { value: "+34 91 123 4567", confidence: 0.89 }
        },
        document_details: {
          document_type: { value: "invoice", confidence: 0.97 },
          document_number: { value: "DEMO-2024-001", confidence: 0.95 },
          document_date: { value: "2024-12-15", confidence: 0.96 }
        },
        line_items: [
          {
            description: { value: "Demo Product 1", confidence: 0.94 },
            quantity: { value: 1, confidence: 0.92 },
            unit_price: { value: 10.00, confidence: 0.93 },
            total_price: { value: 10.00, confidence: 0.95 }
          },
          {
            description: { value: "Demo Product 2", confidence: 0.96 },
            quantity: { value: 2, confidence: 0.98 },
            unit_price: { value: 15.50, confidence: 0.94 },
            total_price: { value: 31.00, confidence: 0.95 }
          }
        ]
      },
      processing_info: {
        api_used: "demo_fallback",
        timestamp: new Date().toISOString(),
