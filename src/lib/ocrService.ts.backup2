}

// Convert Mindee response to legacy format for backward compatibility
function convertMindeeToLegacyFormat(ocrResult: OCRResult): ExtractDataResult {
  if (!ocrResult.success || !ocrResult.data) {
    return {
      products: [],
      supplier: { name: 'Unknown' },
      invoiceTotal: 0,
      invoiceNumber: '',
      invoiceDate: ''
    };
  }

  const data = ocrResult.data;
  const products: OCRProduct[] = data.components.line_items.map(item => ({
    name: item.description.value,
    price: item.unit_price.value,
    quantity: item.quantity.value,
    discount: 0,
    vat_rate: 21, // Default VAT rate
    total: item.total_price.value,
    originalPrice: item.unit_price.value,
    discountPercent: 0,
    vatRate: 21,
    uncertain: false
  }));

  return {
    products,
    supplier: { name: data.components.vendor_details.vendor_name.value },
    invoiceTotal: data.components.amount_details.amount_total.value,
    invoiceNumber: data.components.document_details.document_number.value,
    invoiceDate: data.components.document_details.document_date.value
  };
}

// Legacy function for backward compatibility
export async function extractInvoiceItems(imageFile: File): Promise<{ items: OCRProduct[] }> {
  console.log('🔄 Extracting invoice items only...');
  const ocrResult = await extractDataFromImage(imageFile, 'products');
  const legacyResult = convertMindeeToLegacyFormat(ocrResult);
  return { items: legacyResult.products };
}

// Extract invoice data (main function)
export async function extractInvoiceData(
  imageFile: File,
  onProgress?: OCRProgressCallback
): Promise<InvoiceDataExtracted> {
  console.log('🔄 Starting full invoice extraction...');
  
  try {
    // Simulate progress for UI
    onProgress?.(1, 0, undefined, 5);
    
    const ocrResult = await extractDataFromImage(imageFile, 'invoice');
    
    onProgress?.(2, 50);
    
    if (!ocrResult.success || !ocrResult.data) {
      onProgress?.(3, 100);
      return {};
    }

    const data = ocrResult.data;
    
    onProgress?.(3, 100);
    
    return {
      supplier: { 
        name: data.components.vendor_details.vendor_name.value,
        email: '',
        phone: data.components.vendor_details.vendor_phone.value
      },
      invoiceNumber: data.components.document_details.document_number.value,
      invoiceDate: data.components.document_details.document_date.value,
      date: data.components.document_details.document_date.value,
      totalAmount: data.components.amount_details.amount_total.value,
      amount: data.components.amount_details.amount_total.value,
      items: data.components.line_items.map(item => ({
        name: item.description.value,
        price: item.unit_price.value,
        quantity: item.quantity.value,
        discountPercent: 0,
        vatRate: 21, // Default VAT rate
        uncertain: false
      }))
    };
  } catch (error) {
    console.warn('⚠️ Full invoice extraction failed:', error);
    onProgress?.(3, 100);
    return {};
  }
}
