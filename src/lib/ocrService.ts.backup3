import { supabase } from './supabase';

export interface OCRResult {
  success: boolean;
  data?: {
    components: {
      amount_details: {
        amount_total: { value: number; confidence: number };
        amount_subtotal: { value: number; confidence: number };
        amount_tax: { value: number; confidence: number };
        currency: { value: string; confidence: number };
      };
      vendor_details: {
        vendor_name: { value: string; confidence: number };
        vendor_address: { value: string; confidence: number };
        vendor_vat_number: { value: string; confidence: number };
        vendor_phone: { value: string; confidence: number };
      };
      document_details: {
        document_type: { value: string; confidence: number };
        document_number: { value: string; confidence: number };
        document_date: { value: string; confidence: number };
      };
      line_items: Array<{
        description: { value: string; confidence: number };
        quantity: { value: number; confidence: number };
        unit_price: { value: number; confidence: number };
        total_price: { value: number; confidence: number };
      }>;
    };
    processing_info: {
      api_used: string;
      timestamp: string;
      note: string;
    };
  };
  error?: string;
}

// Legacy interfaces for backward compatibility
interface OCRProduct {
  name: string;
  price: number;
  original_price?: number;
  discount?: number;
  vat_rate?: number;
  quantity?: number;
  category?: string;
  originalPrice?: number;
  discountPercent?: number;
  vatRate?: number;
  uncertain?: boolean;
  total?: number;
}

interface Invoice {
  invoiceNumber?: string;
  date?: string;
  supplier?: string;
  products: OCRProduct[];
  subtotal?: number;
  totalVAT?: number;
  total: number;
}

export interface InvoiceDataExtracted {
  invoiceNumber?: string;
  invoiceDate?: string;
  date?: string;
  amount?: number;
  totalAmount?: number;
  supplier?: { name?: string; email?: string; phone?: string };
  items?: Array<{
    name: string;
    price: number;
    quantity: number;
    originalPrice?: number;
    discountPercent?: number;
    vatRate?: number;
    uncertain?: boolean;
  }>;
}

interface ExtractDataResult {
  products: OCRProduct[];
  supplier: { name: string };
  invoiceTotal: number;
  invoiceNumber: string;
  invoiceDate: string;
}

export interface OCRProgressCallback {
  (phase: 1 | 2 | 3, progress: number, zone?: string, estimatedTime?: number): void;
}

// Convert file to base64
function fileToBase64(file: File): Promise<string> {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.readAsDataURL(file);
    reader.onload = () => resolve(reader.result as string);
    reader.onerror = error => reject(error);
  });
}

// Generate image hash for caching
async function generateImageHash(file: File): Promise<string> {
  const arrayBuffer = await file.arrayBuffer();
  const hashBuffer = await crypto.subtle.digest('SHA-256', arrayBuffer);
  const hashArray = Array.from(new Uint8Array(hashBuffer));
  return hashArray.map(b => b.toString(16).padStart(2, '0')).join('').substring(0, 16);
}

// Direct Mindee API call with CUSTOM MODEL (CORRECTED WITH ORGANIZATION NAME)
async function callMindeeDirectly(file: File): Promise<OCRResult> {
  const apiKey = import.meta.env.VITE_MINDEE_API_KEY;
  
  if (!apiKey) {
    console.error('❌ [DIRECT] MINDEE_API_KEY not found in environment');
    return { success: false, error: 'API key not configured' };
  }

  console.log('🚀 [DIRECT] Testing Mindee CUSTOM MODEL API with Organization Name...');
  console.log('🔑 [DIRECT] API Key found:', apiKey.substring(0, 10) + '...');
  console.log('🏢 [DIRECT] Organization: salvatores-organization');
  console.log('🎯 [DIRECT] Using CUSTOM Model ID: 741f34ce-fb96-427d-8048-dac0c30395fc');

  try {
    const formData = new FormData();
    formData.append('document', file);

    // CORRECTED: Use the correct organization name from Mindee dashboard
    const customModelId = '741f34ce-fb96-427d-8048-dac0c30395fc';
    const orgName = 'salvatores-organization'; // From "salvatore's Organization"
    
    // Try different endpoint formats with correct organization name
    const endpoints = [
      `https://api.mindee.net/v1/products/${orgName}/${customModelId}/v1/predict`,
      `https://api.mindee.net/v1/products/${orgName}/${customModelId}/v2/predict`,
      `https://api.mindee.net/v2/products/${orgName}/${customModelId}/predict`,
      `https://api.mindee.net/v1/products/${orgName}/${customModelId}/predict`
    ];
    
    for (let i = 0; i < endpoints.length; i++) {
      const endpoint = endpoints[i];
      console.log(`📡 [DIRECT] Trying endpoint ${i + 1}/${endpoints.length}:`, endpoint);

      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Authorization': `Token ${apiKey}`,
        },
        body: formData
      });

      console.log(`📡 [DIRECT] Response status for endpoint ${i + 1}:`, response.status);
      
      if (response.status === 401) {
        console.warn(`⚠️ [DIRECT] 401 Unauthorized for endpoint ${i + 1}, trying next...`);
        continue;
      }
      
      if (response.status === 404) {
        console.warn(`⚠️ [DIRECT] 404 Not Found for endpoint ${i + 1}, trying next...`);
        continue;
      }
      
      if (!response.ok) {
        const errorText = await response.text();
        console.error(`❌ [DIRECT] API Error for endpoint ${i + 1}:`, errorText);
        continue;
      }

      // Success! Process the response
      const result = await response.json();
      console.log(`✅ [DIRECT] SUCCESS with endpoint ${i + 1}! Raw result:`, result);
      
      // Convert Mindee custom model response to our format
      const prediction = result.document?.inference?.prediction;
      if (!prediction) {
        console.error('❌ [DIRECT] No prediction data in response');
        continue;
      }

      // For custom models, the structure might be different
      // Let's log the structure to understand it better
      console.log('🔍 [DIRECT] Prediction structure:', JSON.stringify(prediction, null, 2));

      const convertedData = {
        components: {
          amount_details: {
            amount_total: { value: prediction.total_amount?.value || prediction.amount_total?.value || 0, confidence: prediction.total_amount?.confidence || prediction.amount_total?.confidence || 0 },
            amount_subtotal: { value: prediction.total_net?.value || prediction.amount_subtotal?.value || 0, confidence: prediction.total_net?.confidence || prediction.amount_subtotal?.confidence || 0 },
            amount_tax: { value: prediction.total_tax?.value || prediction.amount_tax?.value || 0, confidence: prediction.total_tax?.confidence || prediction.amount_tax?.confidence || 0 },
            currency: { value: prediction.locale?.currency || prediction.currency?.value || 'EUR', confidence: 0.95 }
          },
          vendor_details: {
            vendor_name: { value: prediction.supplier_name?.value || prediction.vendor_name?.value || '', confidence: prediction.supplier_name?.confidence || prediction.vendor_name?.confidence || 0 },
            vendor_address: { value: prediction.supplier_address?.value || prediction.vendor_address?.value || '', confidence: prediction.supplier_address?.confidence || prediction.vendor_address?.confidence || 0 },
            vendor_vat_number: { value: prediction.supplier_company_registrations?.[0]?.value || prediction.vendor_vat_number?.value || '', confidence: prediction.supplier_company_registrations?.[0]?.confidence || prediction.vendor_vat_number?.confidence || 0 },
            vendor_phone: { value: prediction.supplier_phone?.value || prediction.vendor_phone?.value || '', confidence: prediction.supplier_phone?.confidence || prediction.vendor_phone?.confidence || 0 }
          },
          document_details: {
            document_type: { value: 'invoice', confidence: 0.95 },
            document_number: { value: prediction.invoice_number?.value || prediction.document_number?.value || '', confidence: prediction.invoice_number?.confidence || prediction.document_number?.confidence || 0 },
            document_date: { value: prediction.date?.value || prediction.document_date?.value || '', confidence: prediction.date?.confidence || prediction.document_date?.confidence || 0 }
          },
          line_items: (prediction.line_items || []).map((item: any) => ({
            description: { value: item.description?.value || item.product_description?.value || '', confidence: item.description?.confidence || item.product_description?.confidence || 0.9 },
            quantity: { value: item.quantity?.value || 1, confidence: item.quantity?.confidence || 0.9 },
            unit_price: { value: item.unit_price?.value || item.price?.value || 0, confidence: item.unit_price?.confidence || item.price?.confidence || 0.9 },
            total_price: { value: item.total_amount?.value || item.total?.value || 0, confidence: item.total_amount?.confidence || item.total?.confidence || 0.9 }
          }))
        },
        processing_info: {
          api_used: 'mindee_custom_model_org',
          timestamp: new Date().toISOString(),
          note: `Custom Mindee model API call successful with organization endpoint ${i + 1}`
        }
      };

      return {
        success: true,
        data: convertedData
      };
    }
    
    // If we get here, all endpoints failed
    return { success: false, error: 'All endpoint formats failed with organization name' };
    
  } catch (error) {
    console.error('❌ [DIRECT] Network error:', error);
    return { success: false, error: error.message };
  }
}

// Extract data from image using Mindee API
export async function extractDataFromImage(
  file: File,
  mode: 'products' | 'invoice' = 'products'
): Promise<OCRResult> {
  const requestId = crypto.randomUUID().substring(0, 8);
  
  console.log(`🚀 [OCR] Starting OCR process...`);
  console.log(`📄 [OCR] Method: Mindee CUSTOM MODEL with Organization`);
  console.log(`📄 [OCR] Mode: ${mode}`);
  console.log(`🌍 [OCR] Languages: Multi-language support via Mindee`);
  console.log(`🎯 [OCR] Focus: Supplier, Products, Unit Prices, Total`);

  try {
    console.log(`🚀 [MINDEE] Starting Mindee CUSTOM MODEL with Organization OCR processing...`);
    
    // Generate image hash for caching
    const imageHash = await generateImageHash(file);
    console.log(`🔑 [MINDEE] Image hash: ${imageHash}`);

    // TRY DIRECT MINDEE CUSTOM MODEL API WITH ORGANIZATION NAME FIRST
    console.log(`🧪 [TEST] Trying direct Mindee CUSTOM MODEL API with Organization...`);
    const directResult = await callMindeeDirectly(file);
    
    if (directResult.success) {
      console.log(`✅ [DIRECT] Direct CUSTOM MODEL API with Organization call successful!`);
      return directResult;
    } else {
      console.warn(`⚠️ [DIRECT] Direct CUSTOM MODEL API with Organization failed:`, directResult.error);
    }

    // FALLBACK: Try Supabase Edge Function
    console.log(`🔄 [FALLBACK] Trying Supabase Edge Function...`);
    
    // Convert to base64
    console.log(`🖼️ [MINDEE] Converting image to base64...`);
    const imageBase64 = await fileToBase64(file);
    console.log(`🖼️ [MINDEE] Image base64 length: ${imageBase64.length} characters`);

    // Call Mindee API via Edge Function
    console.log(`📡 [MINDEE] Calling mindee_ocr_processor Edge Function...`);
    const { data, error } = await supabase.functions.invoke('mindee_ocr_processor', {
      body: { 
        imageBase64: imageBase64,
        country: 'ES',
        language: 'es'
      }
    });

    if (error) {
      console.error(`❌ [MINDEE] Error details:`, error);
      console.warn(`⚠️ [MINDEE] Falling back to demo processing`);
      return getFallbackDemoData(requestId);
    }

    if (data && data.result === 'success') {
      console.log(`✅ [MINDEE] API SUCCESS - Invoice processed successfully`);
      console.log(`🏢 [MINDEE] Supplier: ${data.data?.components?.vendor_details?.vendor_name?.value}`);
      console.log(`💰 [MINDEE] Total: ${data.data?.components?.amount_details?.amount_total?.value}`);
      return {
        success: true,
        data: data.data
      };
    } else {
      console.warn(`⚠️ [MINDEE] Invalid response format, using demo data`);
      return getFallbackDemoData(requestId);
    }

  } catch (error) {
    console.error(`❌ [MINDEE] Unexpected error:`, error);
    console.warn(`⚠️ [FALLBACK] Using fallback OCR processing`);
    return getFallbackDemoData(requestId);
  }
}

