// ============================================
// ORDERS
// ============================================

export const getOrders = async (): Promise<Order[]> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.warn('⚠️ No user logged in, cannot load orders');
      return [];
    }

    const { data, error } = await supabase
      .from('orders')
      .select('*')
      .eq('user_id', userId)
      .order('created_at', { ascending: false });

    if (error) throw error;

    const orders: Order[] = (data || []).map(item => ({
      id: item.id,
      date: item.order_date || item.created_at,
      order_date: item.order_date,
      items: item.items || [],
      total: item.total,
      status: item.status,
      is_recurring: item.is_recurring,
      recurrence_frequency: item.recurrence_frequency,
      next_order_date: item.next_order_date,
      created_at: item.created_at,
      updated_at: item.updated_at,
      supplier_id: item.supplier_id,
      order_number: item.order_number
    }));

    console.log('📥 Fetched', orders.length, 'orders from Supabase');
    return orders;
  } catch (error) {
    console.error('❌ Error fetching orders:', error);
    return [];
  }
};

export const saveOrders = async (orders: Order[]): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot save orders');
      throw new Error('User not authenticated');
    }

    const ordersData = orders.map(order => ({
      id: order.id,
      user_id: userId,
      order_date: order.date || order.order_date,
      items: order.items || [],
      total: order.total,
      status: order.status,
      is_recurring: order.is_recurring,
      recurrence_frequency: order.recurrence_frequency,
      next_order_date: order.next_order_date,
      supplier_id: order.supplier_id,
      order_number: order.order_number,
      updated_at: new Date().toISOString()
    }));

    const { error } = await supabase
      .from('orders')
      .upsert(ordersData, {
        onConflict: 'id'
      });

    if (error) throw error;
    console.log('✅ Saved', orders.length, 'orders to Supabase');
  } catch (error) {
    console.error('❌ Error saving orders:', error);
    throw error;
  }
};

export const updateOrder = async (id: string, updates: Partial<Order>): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot update order');
      throw new Error('User not authenticated');
    }

    const updateData: Record<string, unknown> = {
      updated_at: new Date().toISOString()
    };

    if (updates.supplier_id !== undefined) updateData.supplier_id = updates.supplier_id;
    if (updates.items !== undefined) updateData.items = updates.items;
    if (updates.status !== undefined) updateData.status = updates.status;
    if (updates.total !== undefined) updateData.total = updates.total;
    if (updates.order_date !== undefined || updates.date !== undefined) {
      updateData.order_date = updates.order_date || updates.date;
    }
    if (updates.is_recurring !== undefined) updateData.is_recurring = updates.is_recurring;
    if (updates.recurrence_frequency !== undefined) updateData.recurrence_frequency = updates.recurrence_frequency;
    if (updates.next_order_date !== undefined) updateData.next_order_date = updates.next_order_date;
    if (updates.order_number !== undefined) updateData.order_number = updates.order_number;

    const { error } = await supabase
      .from('orders')
      .update(updateData)
      .eq('id', id)
      .eq('user_id', userId);

    if (error) throw error;
    console.log('✅ Updated order in Supabase:', id);
  } catch (error) {
    console.error('❌ Error updating order:', error);
    throw error;
  }
};

export const deleteOrder = async (id: string): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot delete order');
      throw new Error('User not authenticated');
    }

    const { error } = await supabase
      .from('orders')
      .delete()
      .eq('id', id)
      .eq('user_id', userId);

    if (error) throw error;
    console.log('✅ Deleted order from Supabase:', id);
  } catch (error) {
    console.error('❌ Error deleting order:', error);
    throw error;
  }
};

// ============================================
// INVOICES - FIXED TO USE CORRECT TABLE NAME
// ============================================

export const getInvoices = async (): Promise<Invoice[]> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.warn('⚠️ No user logged in, cannot load invoices');
      return [];
    }

    console.log('🔵 Fetching invoices for user:', userId);

    // CRITICAL FIX: Use correct table name 'app_43909_invoices'
    const { data, error } = await supabase
      .from('app_43909_invoices')
      .select('*')
      .eq('user_id', userId)
      .order('created_at', { ascending: false });

    if (error) {
      console.error('❌ Supabase error fetching invoices:', error);
      throw error;
    }

    // CRITICAL FIX: Filter out invoices without supplier_id (old/invalid invoices)
    const allInvoices = (data || []).map(item => ({
      id: item.id,
      user_id: item.user_id,
      supplier_id: item.supplier_id,
      supplierId: item.supplier_id,
      order_id: item.order_id,
      invoice_number: item.invoice_number,
      invoiceNumber: item.invoice_number,
      date: item.invoice_date,
      invoice_date: item.invoice_date,
      amount: item.total_amount || 0,
      total: item.total_amount || 0,
      total_amount: item.total_amount || 0,
      vat_amount: item.vat_amount || 0,
      vat_breakdown: item.vat_breakdown || [],
      is_paid: item.is_paid || false,
      isPaid: item.is_paid || false,
      payment_date: item.payment_date,
      supplier_name: item.supplier_name || '',
      items: item.items || [],
      notes: item.notes || '',
      status: item.is_paid ? 'paid' : 'unpaid',
      issued_at: item.issued_at,
      created_at: item.created_at,
      createdAt: item.created_at,
      updated_at: item.updated_at
    }));

    // Filter out invalid invoices (missing supplier_id)
    const validInvoices = allInvoices.filter(invoice => {
      if (!invoice.supplier_id) {
        console.warn(`⚠️ Skipping invoice ${invoice.id} - missing supplier_id (old invoice from before migration)`);
        return false;
      }
      return true;
    });

    const skippedCount = allInvoices.length - validInvoices.length;
    if (skippedCount > 0) {
      console.log(`⚠️ Filtered out ${skippedCount} invalid invoice(s) without supplier_id`);
    }

    console.log('📥 Fetched', validInvoices.length, 'valid invoices from Supabase');
    return validInvoices;
  } catch (error) {
    console.error('❌ Error fetching invoices:', error);
    return [];
  }
};

export const saveInvoices = async (invoices: Invoice[]): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot save invoices');
      throw new Error('User not authenticated');
    }

    // CRITICAL FIX: Don't save empty array during deletion
    if (invoices.length === 0) {
      console.log('⏸️ Skipping save of empty invoices array');
      return;
    }

    console.log('🔵 Saving', invoices.length, 'invoices for user:', userId);

    const invoicesData = invoices.map(invoice => {
      // CRITICAL FIX: Normalize supplier_id from both possible field names
      const supplierId = invoice.supplier_id || invoice.supplierId;
      const invoiceNumber = invoice.invoice_number || invoice.invoiceNumber;
      const invoiceDate = invoice.date || invoice.invoice_date;
      
      // Fix the nullish coalescing issue
      let isPaid = false;
      if (invoice.is_paid !== undefined && invoice.is_paid !== null) {
        isPaid = invoice.is_paid;
      } else if (invoice.isPaid !== undefined && invoice.isPaid !== null) {
        isPaid = invoice.isPaid;
      } else if (invoice.status === 'paid') {
        isPaid = true;
      }
      
      console.log('🔍 [DEBUG] Processing invoice for save:');
      console.log('  - invoice.id:', invoice.id);
      console.log('  - invoice.supplier_id:', invoice.supplier_id);
      console.log('  - invoice.supplierId:', invoice.supplierId);
      console.log('  - Normalized supplierId:', supplierId);
      console.log('  - invoice.invoice_number:', invoice.invoice_number);
      console.log('  - invoice.invoiceNumber:', invoice.invoiceNumber);
      console.log('  - Normalized invoiceNumber:', invoiceNumber);
      console.log('  - invoice.date:', invoice.date);
      console.log('  - invoice.invoice_date:', invoice.invoice_date);
      console.log('  - Normalized invoiceDate:', invoiceDate);
      
      if (!supplierId) {
        console.error('❌ Missing supplier_id for invoice:', invoice.id);
        console.error('   Invoice object:', JSON.stringify(invoice, null, 2));
        throw new Error(`supplier_id is required for invoice ${invoice.id}`);
      }
      if (!invoiceNumber) {
        console.error('❌ Missing invoice_number for invoice:', invoice.id);
        throw new Error(`invoice_number is required for invoice ${invoice.id}`);
      }
      if (!invoiceDate) {
        console.error('❌ Missing date for invoice:', invoice.id);
        throw new Error(`date is required for invoice ${invoice.id}`);
      }

      const invoiceData = {
        id: invoice.id,
        user_id: userId,
        supplier_id: supplierId,
        invoice_number: invoiceNumber,
        supplier_name: invoice.supplier_name || '',
        invoice_date: invoiceDate,
        total_amount: invoice.amount || invoice.total || invoice.total_amount || 0,
        vat_amount: invoice.vat_amount || 0,
        vat_breakdown: invoice.vat_breakdown || [],
        is_paid: isPaid,
        payment_date: invoice.payment_date || null,
        notes: invoice.notes || '',
        items: invoice.items || []
      };

      console.log('📤 [DEBUG] Prepared invoice data for upsert:');
      console.log('  - id:', invoiceData.id);
      console.log('  - user_id:', invoiceData.user_id);
      console.log('  - supplier_id:', invoiceData.supplier_id);
      console.log('  - invoice_number:', invoiceData.invoice_number);
      console.log('  - invoice_date:', invoiceData.invoice_date);
      console.log('  - total_amount:', invoiceData.total_amount);
      console.log('  - vat_amount:', invoiceData.vat_amount);
      console.log('  - is_paid:', invoiceData.is_paid);
      console.log('  - items_count:', invoiceData.items.length);
      console.log('  - Full data:', JSON.stringify(invoiceData, null, 2));
      
      return invoiceData;
    });

    console.log('📤 [DEBUG] About to call Supabase upsert with', invoicesData.length, 'invoice(s)');
    console.log('📤 [DEBUG] First invoice data:', JSON.stringify(invoicesData[0], null, 2));

    // CRITICAL FIX: Use correct table name 'app_43909_invoices'
    const { data, error } = await supabase
      .from('app_43909_invoices')
      .upsert(invoicesData, {
        onConflict: 'id'
      })
      .select();

    if (error) {
      console.error('❌ [DEBUG] Supabase upsert error:', error);
      console.error('   Error code:', error.code);
      console.error('   Error message:', error.message);
      console.error('   Error details:', error.details);
      console.error('   Error hint:', error.hint);
      throw error;
    }
    
    console.log('✅ [DEBUG] Supabase upsert successful');
    console.log('✅ [DEBUG] Returned data:', data);
    console.log('✅ Saved', invoices.length, 'invoices to Supabase');
  } catch (error) {
    console.error('❌ Error saving invoices:', error);
    throw error;
  }
};

export const deleteInvoice = async (id: string): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot delete invoice');
      throw new Error('User not authenticated');
    }

    // CRITICAL FIX: Use correct table name 'app_43909_invoices'
    const { error } = await supabase
      .from('app_43909_invoices')
      .delete()
      .eq('id', id)
      .eq('user_id', userId);

    if (error) throw error;
    console.log('✅ Deleted invoice from Supabase:', id);
  } catch (error) {
    console.error('❌ Error deleting invoice:', error);
    throw error;
  }
};