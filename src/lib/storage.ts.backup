export const getSuppliers = async (): Promise<Supplier[]> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.warn('⚠️ No user logged in, cannot load suppliers');
      return [];
    }

    const { data, error } = await supabase
      .from('suppliers')
      .select('*')
      .eq('user_id', userId)
      .order('name');

    if (error) throw error;

    const suppliers: Supplier[] = (data || []).map(item => ({
      id: item.id,
      name: item.name,
      phone: item.phone,
      mobile: item.mobile,
      email: item.email,
      products: item.products || [],
      address: item.address,
      notes: item.notes,
      country: item.country,
      created_at: item.created_at,
      updated_at: item.updated_at,
      is_whitelisted: item.is_whitelisted,
      contact: item.contact
    }));

    console.log('📥 Fetched', suppliers.length, 'suppliers from Supabase');
    return suppliers;
  } catch (error) {
    console.error('❌ Error fetching suppliers:', error);
    return [];
  }
};

export const saveSuppliers = async (suppliers: Supplier[]): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot save suppliers');
      throw new Error('User not authenticated');
    }

    // CRITICAL FIX: Don't save empty array during deletion
    if (suppliers.length === 0) {
      console.log('⏸️ Skipping save of empty suppliers array');
      return;
    }

    const suppliersData = suppliers.map(supplier => ({
      id: supplier.id,
      user_id: userId,
      name: supplier.name,
      phone: supplier.phone,
      mobile: supplier.mobile,
      email: supplier.email,
      products: supplier.products || [],
      address: supplier.address,
      notes: supplier.notes,
      country: supplier.country,
      is_whitelisted: supplier.is_whitelisted,
      contact: supplier.contact,
      updated_at: new Date().toISOString()
    }));

    const { error } = await supabase
      .from('suppliers')
      .upsert(suppliersData, {
        onConflict: 'id'
      });

    if (error) throw error;
    console.log('✅ Saved', suppliers.length, 'suppliers to Supabase');
  } catch (error) {
    console.error('❌ Error saving suppliers:', error);
    throw error;
  }
};

