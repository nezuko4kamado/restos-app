import { supabase } from './supabase';
import type { 
  Product, 
  Supplier, 
  Order, 
  Invoice, 
  Settings, 
  OrderItem,
  ExtractedInvoiceItem,
  PriceHistory
} from '@/types';

// ============================================
// STORAGE KEYS
// ============================================
const SETTINGS_KEY = 'restaurant_settings';
const PRODUCTS_KEY = 'restaurant_products';
const SUPPLIERS_KEY = 'restaurant_suppliers';
const ORDERS_KEY = 'restaurant_orders';
const INVOICES_KEY = 'restaurant_invoices';

// ============================================
// UTILITY FUNCTIONS
// ============================================

export const isSupabaseConfigured = (): boolean => {
  return !!supabase;
};

const getCurrentUserId = async (): Promise<string | null> => {
  if (!supabase) return null;
  
  const { data: { user } } = await supabase.auth.getUser();
  return user?.id || null;
};

// ============================================
// DRAFT ORDERS - SUPABASE ONLY
// ============================================

export interface DraftOrder {
  orderItems: OrderItem[];
  temporaryOcrProducts?: Product[];
}

export const saveDraftOrder = async (draft: DraftOrder): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    if (!userId) {
      console.error('❌ No user logged in, cannot save draft order');
      throw new Error('User not authenticated');
    }

    await supabase
      .from('draft_orders')
      .delete()
      .eq('user_id', userId);

    const { error } = await supabase
      .from('draft_orders')
      .insert({
        user_id: userId,
        order_items: draft.orderItems,
        temporary_ocr_products: draft.temporaryOcrProducts || []
      });

    if (error) throw error;
    console.log('💾 Saved draft order to Supabase:', draft);
  } catch (error) {
    console.error('❌ Error saving draft order:', error);
    throw error;
  }
};

export const getDraftOrder = async (): Promise<DraftOrder | null> => {
  try {
    const userId = await getCurrentUserId();
    if (!userId) {
      console.log('⚠️ No user logged in, cannot load draft order');
      return null;
    }

    const { data, error } = await supabase
      .from('draft_orders')
      .select('*')
      .eq('user_id', userId)
      .order('updated_at', { ascending: false })
      .limit(1)
      .single();

    if (error) {
      if (error.code === 'PGRST116') {
        return null;
      }
      throw error;
    }

    if (!data) return null;

    const draft: DraftOrder = {
      orderItems: data.order_items || [],
      temporaryOcrProducts: data.temporary_ocr_products || []
    };

    console.log('📥 Loaded draft order from Supabase:', draft);
    return draft;
  } catch (error) {
    console.error('❌ Error loading draft order:', error);
    return null;
  }
};

export const clearDraftOrder = async (): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    if (!userId) {
      console.error('❌ No user logged in, cannot clear draft order');
      return;
    }

    const { error } = await supabase
      .from('draft_orders')
      .delete()
      .eq('user_id', userId);

    if (error) throw error;
    console.log('🗑️ Cleared draft order from Supabase');
  } catch (error) {
    console.error('❌ Error clearing draft order:', error);
  }
};

