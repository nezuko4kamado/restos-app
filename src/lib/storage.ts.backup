// ============================================
// SETTINGS
// ============================================

const DEFAULT_SETTINGS: Settings = {
  country: 'IT',
  language: 'it',
  defaultCurrency: 'EUR',
  fontSize: 'medium',
  layoutMode: 'expanded',
  notifications: {
    price_change_threshold: 10,
    recurring_order_reminder_days: 3,
    enable_recurring_reminders: true
  },
  storeName: 'Il Mio Ristorante'
};

export const loadSettings = async (): Promise<Settings> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.log('⚠️ No user logged in, using default settings');
      return DEFAULT_SETTINGS;
    }

    const { data, error } = await supabase
      .from('user_settings')
      .select('*')
      .eq('user_id', userId)
      .single();

    if (error) {
      if (error.code === 'PGRST116') {
        console.log('📥 No settings found, creating default settings');
        await saveSettings(DEFAULT_SETTINGS);
        return DEFAULT_SETTINGS;
      }
      throw error;
    }

    if (!data) return DEFAULT_SETTINGS;

    const settings: Settings = {
      country: data.country || DEFAULT_SETTINGS.country,
      language: data.language || DEFAULT_SETTINGS.language,
      defaultCurrency: data.default_currency || DEFAULT_SETTINGS.defaultCurrency,
      fontSize: data.font_size || DEFAULT_SETTINGS.fontSize,
      layoutMode: data.layout_mode || DEFAULT_SETTINGS.layoutMode,
      notifications: {
        price_change_threshold: data.price_change_threshold || 10,
        recurring_order_reminder_days: data.recurring_order_reminder_days || 3,
        enable_recurring_reminders: data.enable_recurring_reminders ?? true
      },
      storeName: data.store_name || DEFAULT_SETTINGS.storeName
    };

    console.log('📥 Loaded settings from Supabase:', settings);
    return settings;
  } catch (error) {
    console.error('❌ Error loading settings:', error);
    return DEFAULT_SETTINGS;
  }
};

export const getSettings = loadSettings;

export const saveSettings = async (settings: Settings): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot save settings');
      throw new Error('User not authenticated');
    }

    const settingsData = {
      user_id: userId,
      country: settings.country,
      language: settings.language,
      default_currency: settings.defaultCurrency,
      font_size: settings.fontSize,
      layout_mode: settings.layoutMode,
      price_change_threshold: settings.notifications?.price_change_threshold || 10,
      recurring_order_reminder_days: settings.notifications?.recurring_order_reminder_days || 3,
      enable_recurring_reminders: settings.notifications?.enable_recurring_reminders ?? true,
      store_name: settings.storeName,
      updated_at: new Date().toISOString()
    };

    const { error } = await supabase
      .from('user_settings')
      .upsert(settingsData, {
        onConflict: 'user_id'
      });

    if (error) throw error;
    console.log('✅ Saved settings to Supabase:', settings);
  } catch (error) {
    console.error('❌ Error saving settings:', error);
    throw error;
  }
};

// ============================================
// PRODUCTS
// ============================================

export const getProducts = async (): Promise<Product[]> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.warn('⚠️ No user logged in, cannot load products');
      return [];
    }

    const { data, error } = await supabase
      .from('products')
      .select('*')
      .eq('user_id', userId)
      .order('name');

    if (error) throw error;

    const products: Product[] = (data || []).map(item => ({
      id: item.id,
      name: item.name,
      price: item.price,
      image: item.image,
      supplierId: item.supplier_id,
      supplier_id: item.supplier_id,
      category: item.category,
      priceHistory: item.price_history || [],
      price_history: item.price_history || [],
      vatRate: item.vat_rate,
      vat_rate: item.vat_rate,
      discountPercent: item.discount_percent,
      originalPrice: item.original_price,
      original_price: item.original_price,
      discount: item.discount,
      unit: item.unit,
      notes: item.notes,
      code: item.code,
      ean_code: item.ean_code,
      created_at: item.created_at,
      updated_at: item.updated_at,
      last_price_change: item.last_price_change,
      stock_quantity: item.stock_quantity,
      min_stock_level: item.min_stock_level
    }));

    console.log('📥 Fetched', products.length, 'products from Supabase');
    return products;
  } catch (error) {
    console.error('❌ Error fetching products:', error);
    return [];
  }
};

export const saveProducts = async (products: Product[]): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot save products');
      throw new Error('User not authenticated');
    }

    const uniqueProducts = Array.from(
      new Map(products.map(p => [p.id, p])).values()
    );

    const productsData = uniqueProducts.map(product => ({
      id: product.id,
      user_id: userId,
      name: product.name,
      price: product.price,
      image: product.image,
      supplier_id: product.supplierId || product.supplier_id,
      category: product.category,
      price_history: product.priceHistory || product.price_history || [],
      vat_rate: product.vatRate || product.vat_rate,
      discount_percent: product.discountPercent,
      original_price: product.originalPrice || product.original_price,
      discount: product.discount,
      unit: product.unit,
      notes: product.notes,
      code: product.code,
      ean_code: product.ean_code,
      stock_quantity: product.stock_quantity,
      min_stock_level: product.min_stock_level,
      updated_at: new Date().toISOString()
    }));

    const { error } = await supabase
      .from('products')
      .upsert(productsData, {
        onConflict: 'id'
      });

    if (error) throw error;
    console.log('✅ Saved', uniqueProducts.length, 'products to Supabase');
  } catch (error) {
    console.error('❌ Error saving products:', error);
    throw error;
  }
};

export const addProduct = async (productData: Partial<Product>): Promise<Product> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot add product');
      throw new Error('User not authenticated');
    }

    const newProductData = {
      user_id: userId,
      name: productData.name,
      price: productData.price,
      image: productData.image,
      supplier_id: productData.supplier_id || productData.supplierId,
      category: productData.category || 'general',
      price_history: productData.priceHistory || productData.price_history || [],
      vat_rate: productData.vatRate || productData.vat_rate,
      discount_percent: productData.discountPercent,
      original_price: productData.originalPrice || productData.original_price,
      discount: productData.discount,
      unit: productData.unit || 'kg',
      notes: productData.notes,
      code: productData.code,
      ean_code: productData.ean_code,
      stock_quantity: productData.stock_quantity,
      min_stock_level: productData.min_stock_level,
      created_at: new Date().toISOString(),
      updated_at: new Date().toISOString()
    };

    const { data, error } = await supabase
      .from('products')
      .insert(newProductData)
      .select()
      .single();

    if (error) throw error;

    const product: Product = {
      id: data.id,
      name: data.name,
      price: data.price,
      image: data.image,
      supplierId: data.supplier_id,
      supplier_id: data.supplier_id,
      category: data.category,
      priceHistory: data.price_history || [],
      price_history: data.price_history || [],
      vatRate: data.vat_rate,
      vat_rate: data.vat_rate,
      discountPercent: data.discount_percent,
      originalPrice: data.original_price,
      original_price: data.original_price,
      discount: data.discount,
      unit: data.unit,
      notes: data.notes,
      code: data.code,
      ean_code: data.ean_code,
      created_at: data.created_at,
      updated_at: data.updated_at,
      last_price_change: data.last_price_change,
      stock_quantity: data.stock_quantity,
      min_stock_level: data.min_stock_level
    };

    console.log('✅ Added product to Supabase:', product.name);
    return product;
  } catch (error) {
    console.error('❌ Error adding product:', error);
    throw error;
  }
};

export const updateProduct = async (id: string, updates: Partial<Product>): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot update product');
      throw new Error('User not authenticated');
    }

    const updateData: Record<string, unknown> = {
      updated_at: new Date().toISOString()
    };

    if (updates.name !== undefined) updateData.name = updates.name;
    if (updates.price !== undefined) updateData.price = updates.price;
    if (updates.image !== undefined) updateData.image = updates.image;
    if (updates.supplier_id !== undefined || updates.supplierId !== undefined) {
      updateData.supplier_id = updates.supplier_id || updates.supplierId;
    }
    if (updates.category !== undefined) updateData.category = updates.category;
    if (updates.priceHistory !== undefined || updates.price_history !== undefined) {
      updateData.price_history = updates.priceHistory || updates.price_history;
    }
    if (updates.vatRate !== undefined || updates.vat_rate !== undefined) {
      updateData.vat_rate = updates.vatRate || updates.vat_rate;
    }
    if (updates.discountPercent !== undefined) updateData.discount_percent = updates.discountPercent;
    if (updates.originalPrice !== undefined || updates.original_price !== undefined) {
      updateData.original_price = updates.originalPrice || updates.original_price;
    }
    if (updates.discount !== undefined) updateData.discount = updates.discount;
    if (updates.unit !== undefined) updateData.unit = updates.unit;
    if (updates.notes !== undefined) updateData.notes = updates.notes;
    if (updates.code !== undefined) updateData.code = updates.code;
    if (updates.ean_code !== undefined) updateData.ean_code = updates.ean_code;
    if (updates.stock_quantity !== undefined) updateData.stock_quantity = updates.stock_quantity;
    if (updates.min_stock_level !== undefined) updateData.min_stock_level = updates.min_stock_level;
    if (updates.last_price_change !== undefined) updateData.last_price_change = updates.last_price_change;

    const { error } = await supabase
      .from('products')
      .update(updateData)
      .eq('id', id)
      .eq('user_id', userId);

    if (error) throw error;
    console.log('✅ Updated product in Supabase:', id);
  } catch (error) {
    console.error('❌ Error updating product:', error);
    throw error;
  }
};

export const deleteProduct = async (id: string): Promise<void> => {
  try {
    const userId = await getCurrentUserId();
    
    if (!userId) {
      console.error('❌ No user logged in, cannot delete product');
      throw new Error('User not authenticated');
    }

    const { error } = await supabase
      .from('products')
      .delete()
      .eq('id', id)
      .eq('user_id', userId);

    if (error) throw error;
    console.log('✅ Deleted product from Supabase:', id);
  } catch (error) {
    console.error('❌ Error deleting product:', error);
    throw error;
  }
};

