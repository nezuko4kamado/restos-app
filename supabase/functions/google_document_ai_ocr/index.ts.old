import { serve } from 'https://deno.land/std@0.168.0/http/server.ts'
import { create, getNumericDate } from 'https://deno.land/x/djwt@v2.8/mod.ts'
import { createClient } from 'https://esm.sh/@supabase/supabase-js@2.39.3'

const GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT = Deno.env.get('GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT')
const OPENAI_API_KEY = Deno.env.get('OPENAI_API_KEY')
const SUPABASE_URL = Deno.env.get('SUPABASE_URL')!
const SUPABASE_ANON_KEY = Deno.env.get('SUPABASE_ANON_KEY')!

// Google Cloud Document AI Configuration
// IMPORTANT: Using Custom Extractor trained for handwritten orders
const PROJECT_ID = '609032141767'
const LOCATION = 'eu'
const PROCESSOR_ID = '8e21390dd7276cdb'  // Custom Extractor: ordini-handwriting-extractor
const DOCUMENT_AI_ENDPOINT = `https://${LOCATION}-documentai.googleapis.com/v1/projects/${PROJECT_ID}/locations/${LOCATION}/processors/${PROCESSOR_ID}:process`

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
}

interface OrderItem {
  name: string
  quantity: number
  price: number
  unit?: string
  vatRate?: number
  totalLine: number
}

interface OCRResult {
  success: boolean
  supplier: {
    name: string
    id?: string
    phone?: string
  }
  orderItems: OrderItem[]
  totalAmount: number
  error?: string
}

/**
 * Calculate similarity between two strings using Levenshtein distance
 */
function calculateSimilarity(str1: string, str2: string): number {
  const s1 = str1.toLowerCase().trim()
  const s2 = str2.toLowerCase().trim()
  
  if (s1 === s2) return 1.0
  
  // Simple fuzzy matching: check if one contains the other
  if (s1.includes(s2) || s2.includes(s1)) {
    return 0.8
  }
  
  // Levenshtein distance
  const matrix: number[][] = []
  for (let i = 0; i <= s1.length; i++) {
    matrix[i] = [i]
  }
  for (let j = 0; j <= s2.length; j++) {
    matrix[0][j] = j
  }
  for (let i = 1; i <= s1.length; i++) {
    for (let j = 1; j <= s2.length; j++) {
      if (s1[i - 1] === s2[j - 1]) {
        matrix[i][j] = matrix[i - 1][j - 1]
      } else {
        matrix[i][j] = Math.min(
          matrix[i - 1][j - 1] + 1,
          matrix[i][j - 1] + 1,
          matrix[i - 1][j] + 1
        )
      }
    }
  }
  const distance = matrix[s1.length][s2.length]
  const maxLength = Math.max(s1.length, s2.length)
  return 1 - distance / maxLength
}

/**
 * Generate OAuth 2.0 access token using Service Account
 */
async function getAccessToken(): Promise<string> {
  if (!GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT) {
    throw new Error('GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT secret not found')
  }

  const serviceAccount = JSON.parse(GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT)
  const privateKey = serviceAccount.private_key
  const clientEmail = serviceAccount.client_email

  // Import the private key for signing
  const keyData = privateKey
    .replace('-----BEGIN PRIVATE KEY-----', '')
    .replace('-----END PRIVATE KEY-----', '')
    .replace(/\s/g, '')
  
  const binaryKey = Uint8Array.from(atob(keyData), c => c.charCodeAt(0))
  
  const cryptoKey = await crypto.subtle.importKey(
    'pkcs8',
    binaryKey,
    {
      name: 'RSASSA-PKCS1-v1_5',
      hash: 'SHA-256',
    },
    false,
    ['sign']
  )

  // Create JWT
  const now = Math.floor(Date.now() / 1000)
  const jwt = await create(
    { alg: 'RS256', typ: 'JWT' },
    {
      iss: clientEmail,
      scope: 'https://www.googleapis.com/auth/cloud-platform',
      aud: 'https://oauth2.googleapis.com/token',
      exp: now + 3600,
      iat: now,
    },
    cryptoKey
  )

  console.log('🔑 [OAuth] JWT created successfully')

  // Exchange JWT for access token
  const tokenResponse = await fetch('https://oauth2.googleapis.com/token', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/x-www-form-urlencoded',
    },
    body: new URLSearchParams({
      grant_type: 'urn:ietf:params:oauth:grant-type:jwt-bearer',
      assertion: jwt,
    }),
  })

  if (!tokenResponse.ok) {
    const errorText = await tokenResponse.text()
    console.error('❌ [OAuth] Token exchange failed:', errorText)
    throw new Error(`Failed to get access token: ${tokenResponse.status} - ${errorText}`)
  }

  const tokenData = await tokenResponse.json()
  console.log('✅ [OAuth] Access token obtained successfully')
  
  return tokenData.access_token
}

serve(async (req) => {
  // Handle CORS preflight requests
  if (req.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders })
  }

  try {
    console.log('🚀 [Google Document AI OCR] Starting order extraction...')

    const { image } = await req.json()

    if (!image) {
      throw new Error('No image provided')
    }

    // Get authorization header for user authentication
    // Get authorization header for user authentication
    // Try both lowercase and uppercase versions
    const authHeader = req.headers.get('authorization') || req.headers.get('Authorization')
    console.log('🔐 [Auth] Authorization header present:' , !!authHeader)
    console.log('🔐 [Auth] Authorization header (first 20 chars):' , authHeader?.substring(0, 20))
    
    const supabaseClient = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
      global: {
        headers: authHeader ? { Authorization: authHeader } : {},
      },
    })

    // Get current user
    console.log('👤 [Auth] Attempting to get user...')
    const { data: { user }, error: userError } = await supabaseClient.auth.getUser()
    
    if (userError) {
      console.error('❌ [Auth] Error getting user:' , userError)
      console.error('❌ [Auth] Error details:' , JSON.stringify(userError, null, 2))
    }
    
    if (!user) {
      console.error('❌ [Auth] No user found')
      console.error('❌ [Auth] Auth header was:' , authHeader ? 'present' : 'missing')
      throw new Error('User not authenticated')
    }

    console.log('👤 [Auth] User authenticated:', user.id)

    // Extract base64 content (remove data URL prefix if present)
    const base64Content = image.includes(',') ? image.split(',')[1] : image

    // Step 1: Get OAuth 2.0 access token
    console.log('🔐 [OAuth] Getting access token...')
    const accessToken = await getAccessToken()

    // Step 2: Extract text using Google Cloud Document AI Custom Extractor
    console.log('📸 [Document AI] Calling Custom Extractor API...')
    console.log('📍 [Document AI] Endpoint:', DOCUMENT_AI_ENDPOINT)
    console.log('📍 [Document AI] Processor Type: Custom Extractor (ordini-handwriting-extractor)')
    
    // Simplified payload for Custom Extractor processor
    const documentAIResponse = await fetch(DOCUMENT_AI_ENDPOINT, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${accessToken}`,
      },
      body: JSON.stringify({
        rawDocument: {
          mimeType: 'image/jpeg',
          content: base64Content,
        },
      }),
    })

    if (!documentAIResponse.ok) {
      const errorText = await documentAIResponse.text()
      console.error('❌ [Document AI] API Error:', errorText)
      throw new Error(`Document AI API error: ${documentAIResponse.status} - ${errorText}`)
    }

    const documentAIData = await documentAIResponse.json()
    console.log('✅ [Document AI] Text extracted successfully')

    // Extract text from Document AI response
    const extractedText = documentAIData.document?.text || ''

    if (!extractedText) {
      throw new Error('No text extracted from image')
    }

    console.log('📝 [Document AI] Extracted text length:', extractedText.length)
    console.log('📝 [Document AI] First 500 chars:', extractedText.substring(0, 500))

    // SUPPLIER EXTRACTION: Multi-level strategy for robust extraction
    const textLines = extractedText.split('\n').filter(line => line.trim().length > 0)

    console.log('🏢 [Supplier Extraction] Total lines:', textLines.length)
    console.log('🏢 [Supplier Extraction] First 10 lines:', textLines.slice(0, 10))

    // Helper function to check if line is valid supplier name
    function isValidSupplierLine(line: string): boolean {
      const cleaned = line.trim()
      
      // Ignore empty or too short
      if (cleaned.length < 3 || cleaned.length > 50) return false
      
      // Ignore lines with only numbers
      if (/^\d+$/.test(cleaned)) return false
      
      // Ignore lines with dates
      if (/\d{1,2}[\/\-]\d{1,2}[\/\-]\d{2,4}/.test(cleaned)) return false
      
      // Ignore lines with common order document keywords
      const ignorePatterns = /^(data|date|documento|document|ordine|order|n°|num|numero|number|camarero|mesa|cantidad|concepto|precio|total|fecha|iva|subtotal|descuento|discount)$/gi
      if (ignorePatterns.test(cleaned)) return false
      
      // Ignore lines that are mostly numbers (e.g., "629" or "39 06")
      const wordCount = cleaned.split(/\s+/).length
      const numberCount = (cleaned.match(/\d+/g) || []).length
      if (numberCount >= wordCount) return false
      
      return true
    }

    // Helper function to clean supplier name
    function cleanSupplierName(line: string): string {
      return line
        .replace(/data|date|documento|document|ordine|order|n°|num|numero|number|camarero|mesa|cantidad|concepto|precio|total|fecha/gi, '')
        .replace(/[^\w\s]/g, ' ') // Remove special characters
        .replace(/\s+/g, ' ') // Normalize spaces
        .trim()
    }

    // Strategy 1: Check first 3 lines (main title area)
    let extractedSupplierName = ''
    let extractionStrategy = ''

    for (let i = 0; i < Math.min(3, textLines.length); i++) {
      const line = textLines[i]
      if (isValidSupplierLine(line)) {
        const cleaned = cleanSupplierName(line)
        if (cleaned.length >= 3) {
          extractedSupplierName = cleaned
          extractionStrategy = `Strategy 1: Line ${i + 1} (main title)`
          console.log(`✅ [Supplier Extraction] ${extractionStrategy}: "${extractedSupplierName}"`)
          break
        }
      }
    }

    // Strategy 2: If not found, check lines 4-10 (header area)
    if (!extractedSupplierName) {
      for (let i = 3; i < Math.min(10, textLines.length); i++) {
        const line = textLines[i]
        if (isValidSupplierLine(line)) {
          const cleaned = cleanSupplierName(line)
          if (cleaned.length >= 3) {
            extractedSupplierName = cleaned
            extractionStrategy = `Strategy 2: Line ${i + 1} (header area)`
            console.log(`✅ [Supplier Extraction] ${extractionStrategy}: "${extractedSupplierName}"`)
            break
          }
        }
      }
    }

    // Strategy 3: If still not found, check all lines for uppercase words (typical for titles)
    if (!extractedSupplierName) {
      for (let i = 0; i < Math.min(20, textLines.length); i++) {
        const line = textLines[i]
        // Look for lines with mostly uppercase letters (typical for company names)
        const uppercaseRatio = (line.match(/[A-Z]/g) || []).length / line.length
        if (uppercaseRatio > 0.5 && isValidSupplierLine(line)) {
          const cleaned = cleanSupplierName(line)
          if (cleaned.length >= 3) {
            extractedSupplierName = cleaned
            extractionStrategy = `Strategy 3: Line ${i + 1} (uppercase pattern)`
            console.log(`✅ [Supplier Extraction] ${extractionStrategy}: "${extractedSupplierName}"`)
            break
          }
        }
      }
    }

    if (!extractedSupplierName) {
      console.log('⚠️ [Supplier Extraction] No valid supplier name found in document')
      extractedSupplierName = 'Unknown'
    }

    console.log('🏢 [Supplier Extraction] Final extracted name:', extractedSupplierName)
    console.log('🏢 [Supplier Extraction] Extraction strategy:', extractionStrategy)

    // Fetch existing suppliers from database
    const { data: existingSuppliers, error: suppliersError } = await supabaseClient
      .from('suppliers')
      .select('id, name')
      .eq('user_id', user.id)

    if (suppliersError) {
      console.error('❌ [Supplier Extraction] Error fetching suppliers:', suppliersError)
    }

    console.log('📊 [Supplier Extraction] Found', existingSuppliers?.length || 0, 'existing suppliers')

    // Find best match using fuzzy matching
    let matchedSupplier: { id: string; name: string } | null = null
    let bestSimilarity = 0

    if (existingSuppliers && existingSuppliers.length > 0 && extractedSupplierName) {
      for (const supplier of existingSuppliers) {
        const similarity = calculateSimilarity(extractedSupplierName, supplier.name)
        console.log(`🔍 [Supplier Matching] "${extractedSupplierName}" vs "${supplier.name}": ${(similarity * 100).toFixed(1)}%`)
        
        if (similarity > bestSimilarity) {
          bestSimilarity = similarity
          matchedSupplier = supplier
        }
      }
    }

    // Use matched supplier if similarity >= 60%, otherwise "Unknown Supplier"
    let finalSupplierName = 'Unknown Supplier'
    let finalSupplierId: string | undefined = undefined

    if (matchedSupplier && bestSimilarity >= 0.6) {  // Lowered threshold to 60% for better matching
      finalSupplierName = matchedSupplier.name
      finalSupplierId = matchedSupplier.id
      console.log(`✅ [Supplier Matching] Match found: "${extractedSupplierName}" → "${finalSupplierName}" (${(bestSimilarity * 100).toFixed(1)}%)`)
    } else {
      console.log(`⚠️ [Supplier Matching] No match found for "${extractedSupplierName}" (best: ${(bestSimilarity * 100).toFixed(1)}%)`)
      console.log(`⚠️ [Supplier Matching] Using "Unknown Supplier" - user must select manually`)
    }

    // Step 3: Use GPT-4 to structure the data
    console.log('🤖 [GPT-4] Processing extracted text...')
    const gptResponse = await fetch('https://api.openai.com/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${OPENAI_API_KEY}`,
      },
      body: JSON.stringify({
        model: 'gpt-4o',
        messages: [
          {
            role: 'system',
            content: `You are an expert at extracting structured data from Italian handwritten order documents (ordini scritti a mano).

IMPORTANT RULES FOR HANDWRITTEN ORDERS:
- These are HANDWRITTEN orders - expect messy, unclear text
- Extract ALL products/items found, even if information is incomplete or unclear
- Be VERY flexible with spelling errors and handwriting recognition mistakes
- The supplier name has already been extracted from the document header: "${finalSupplierName}"
- Common Italian terms: "Descrizione" (description), "Qta/Qt" (quantity), "Prezzo" (price), "Totale" (total), "IVA" (VAT)
- Accept partial information - it's better to extract incomplete data than nothing
- Try to interpret unclear handwriting based on context

=== QUANTITY EXTRACTION RULES ===
Quantity can be written in many ways - extract the NUMBER:
- "x2" or "2x" → quantity: 2
- "2 pz" or "2pz" → quantity: 2, unit: "pz"
- "2kg" or "2 kg" → quantity: 2, unit: "kg"
- "2 lt" or "2lt" → quantity: 2, unit: "lt"
- "2 conf" → quantity: 2, unit: "conf"
- Just "2" near product name → quantity: 2
- If no quantity found → use 1 as default

EXAMPLES:
- "Rigatoni x2" → name: "Rigatoni", quantity: 2
- "Ricotta 1kg" → name: "Ricotta", quantity: 1, unit: "kg"
- "Focaccia x 5 pz" → name: "Focaccia", quantity: 5, unit: "pz"
- "Olive 3" → name: "Olive", quantity: 3
- "Mozzarella" (no quantity) → name: "Mozzarella", quantity: 1

=== PRODUCT NAME EXTRACTION RULES ===
Product names may be abbreviated, misspelled, or partially illegible:
- Extract what you can see, even if spelling is uncertain
- Product names may span multiple lines
- Common misspellings to recognize:
  * "Rigatons" → probably "Rigatoni"
  * "Kicotta" or "Ricota" → probably "Ricotta"
  * "Foccaccia" or "Focacia" → probably "Focaccia"
  * "Ol!ve" or "01ive" → probably "Olive"
  * "Acc:runns" → probably "Aceitunas"
  * "Strigol1" → probably "Strigoli"
- If a word looks like a food/product name, include it even if spelling is uncertain
- Remove incomplete suffixes (1-2 letters at end): "Crema Forte fo" → "Crema Forte"

=== UNIT EXTRACTION RULES ===
Extract unit from quantity field if present:
- "kg" or "Kg" or "KG" → unit: "kg"
- "pz" or "Pz" or "PZ" or "pezzi" → unit: "pz"
- "lt" or "Lt" or "LT" or "litri" → unit: "lt"
- "conf" or "Conf" or "confezione" → unit: "conf"
- "gr" or "Gr" or "grammi" → unit: "gr"
- If no unit found → leave null

=== PRICE EXTRACTION RULES ===
- Look for numbers with € symbol or after "Prezzo" label
- Format: "€15.50" or "15,50" or "15.50"
- If price is missing (common in handwritten orders) → use 0
- If total line is missing → use 0

Extract:
1. Use the pre-extracted supplier name: "${finalSupplierName}"
2. Supplier phone (if visible and legible in the text)
3. ALL products with available info:
   - name (descrizione prodotto) - accept misspellings, remove incomplete suffixes
   - quantity (quantità) - convert text like "x2" to number 2, default to 1 if missing
   - price (prezzo unitario) - use 0 if not found
   - unit (unità: kg, pz, lt, conf, gr) - extract from quantity field if present
   - VAT rate (aliquota IVA) if shown
   - total line (totale riga) - use 0 if missing
4. Total amount (totale ordine) - use 0 if not visible

Return ONLY valid JSON:
{
  "supplier": {"name": "${finalSupplierName}", "phone": "..." or null},
  "orderItems": [
    {
      "name": "Product name (cleaned, even if misspelled)",
      "quantity": 2,
      "price": 0,
      "unit": "kg",
      "vatRate": null,
      "totalLine": 0
    }
  ],
  "totalAmount": 0
}

If a field is unknown, use null for strings or 0 for numbers. ALWAYS extract products even if incomplete or unclear.`,
          },
          {
            role: 'user',
            content: `Extract order information from this Italian HANDWRITTEN order document:\n\n${extractedText}`,
          },
        ],
        temperature: 0.1,
        max_tokens: 4000,
      }),
    })

    if (!gptResponse.ok) {
      const errorText = await gptResponse.text()
      console.error('❌ [GPT-4] API Error:', errorText)
      throw new Error(`GPT-4 API error: ${gptResponse.status}`)
    }

    const gptData = await gptResponse.json()
    console.log('✅ [GPT-4] Data structured successfully')

    const gptContent = gptData.choices[0]?.message?.content || ''
    console.log('📝 [GPT-4] Full response:', gptContent)
    
    // Parse JSON from GPT response (remove markdown code blocks if present)
    let structuredData
    try {
      const jsonMatch = gptContent.match(/\{[\s\S]*\}/)
      if (jsonMatch) {
        structuredData = JSON.parse(jsonMatch[0])
      } else {
        structuredData = JSON.parse(gptContent)
      }
      console.log('✅ [GPT-4] JSON parsed successfully')
      console.log('📊 [GPT-4] Parsed data:', JSON.stringify(structuredData, null, 2))
    } catch (parseError) {
      console.error('❌ [GPT-4] JSON Parse Error:', parseError)
      console.error('📝 [GPT-4] GPT Response that failed to parse:', gptContent)
      throw new Error('Failed to parse GPT-4 response as JSON')
    }

    // Validate and format the response
    const result: OCRResult = {
      success: true,
      supplier: {
        name: finalSupplierName,
        id: finalSupplierId,
        phone: structuredData.supplier?.phone || undefined,
      },
      orderItems: (structuredData.orderItems || []).map((item: any) => ({
        name: item.name || 'Unknown Product',
        quantity: Number(item.quantity) || 0,
        price: Number(item.price) || 0,
        unit: item.unit || undefined,
        vatRate: item.vatRate ? Number(item.vatRate) : undefined,
        totalLine: Number(item.totalLine) || 0,
      })),
      totalAmount: Number(structuredData.totalAmount) || 0,
    }

    console.log('✅ [Document AI OCR] Extraction completed successfully')
    console.log('📊 [Results] Supplier:', result.supplier.name, '(ID:', result.supplier.id || 'none', ')')
    console.log('📊 [Results] Items extracted:', result.orderItems.length)
    console.log('📊 [Results] Total amount:', result.totalAmount)
    console.log('📊 [Results] First item:', result.orderItems[0] || 'No items')

    return new Response(JSON.stringify(result), {
      headers: { ...corsHeaders, 'Content-Type': 'application/json' },
      status: 200,
    })
  } catch (error) {
    console.error('❌ [Document AI OCR] Error:', error)
    
    const errorResult: OCRResult = {
      success: false,
      supplier: { name: 'Error' },
      orderItems: [],
      totalAmount: 0,
      error: error.message || 'Unknown error occurred',
    }

    return new Response(JSON.stringify(errorResult), {
      headers: { ...corsHeaders, 'Content-Type': 'application/json' },
      status: 200, // Return 200 even for errors to handle them in frontend
    })
  }
})